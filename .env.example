# Forumly configuration — copy to .env and adjust.

# Port the server listens on
PORT=5366

# Moderator (admin) password for the /admin login — CHANGE THIS
ADMIN_PASSWORD=change-me

# Where the SQLite database lives
# DB_PATH=./data/forumly.db

# Spam defense tuning (sensible defaults, usually leave alone)
# RATE_LIMIT_MAX=10          # max posts per IP per window
# RATE_LIMIT_WINDOW_MS=60000 # rate-limit window in ms
# MIN_POST_MS=2000           # minimum ms between opening the composer and posting
